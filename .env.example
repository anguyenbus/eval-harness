# ====================================================================
# eval-harness Environment Configuration
# ====================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: .env is git-ignored. Never commit .env to version control.
# ====================================================================

# ====================================================================
# REQUIRED: OpenAI API Key
# ====================================================================
# Required for DeepEval LLM-judge metrics (Faithfulness, ContextualPrecision,
# ContextualRecall, AnswerRelevancy).
#
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ====================================================================
# OPTIONAL: RAG Generator Model
# ====================================================================
# For stub-local RAG system (demo/reference implementation only).
#
# Options:
#   - gpt-4o-mini (OpenAI, requires OPENAI_API_KEY, faster/cheaper)
#   - gpt-4-turbo (OpenAI)
#   - anthropic.claude-3-5-sonnet-20241022-v2:0 (AWS Bedrock, requires AWS credentials)
RAG_GENERATOR_MODEL=gpt-4o-mini

# ====================================================================
# SECURITY: THIRD-PARTY TELEMETRY DISABLED
# ====================================================================
# DeepEval telemetry is PERMANENTLY DISABLED in this repository.
#
# The setting below is enforced in code (deepeval_config.py) and CANNOT be
# overridden via .env or environment variables.
#
# DO NOT modify or remove the following line from the codebase:
#   os.environ["DEEPEVAL_TELEMETRY_OPT_OUT"] = "YES"
#
# Why telemetry is disabled:
# 1. Privacy: Evaluation runs may contain sensitive query data
# 2. Security: Telemetry sends data to external servers
# 3. Compliance: Many organizations prohibit external telemetry
# 4. Cost: Telemetry consumes bandwidth
#
# If you need to verify telemetry is disabled, check for outbound connections
# to confusingproxy.com or similar in your network monitoring tools.
# ====================================================================

# ====================================================================
# OPTIONAL: AWS Credentials (for Bedrock only)
# ====================================================================
# Only required if using AWS Bedrock as the LLM provider.
# These are typically handled by AWS credential chain (~/.aws/credentials,
# IAM role, etc.) but can be set explicitly if needed.
#
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# ====================================================================
# OPTIONAL: DeepEval Concurrency
# ====================================================================
# Maximum number of concurrent DeepEval evaluations.
# Default: 10. Increase for faster evals, decrease if you hit rate limits.
# DEEPEVAL_MAX_CONCURRENT=10

# ====================================================================
# OPTIONAL: Phoenix Observability
# ====================================================================
# Phoenix (Arize AI) is used for trace visualization and debugging.
# Telemetry is opt-in and disabled by default.
#
# To enable Phoenix telemetry (optional):
#   export PHOENIX_TELEMETRY_ENABLED=false
#
# See: docs/architecture/evaluation-system-architecture.md
# ====================================================================
